# ══════════════════════════════════════════════════════════════════
# AgriSearch — Variables de entorno
# Copia este archivo como .env y completa los valores necesarios.
# ══════════════════════════════════════════════════════════════════

# --- LLM (Ollama) ---
LITELLM_MODEL=ollama/aya:8b
LITELLM_API_BASE=http://localhost:11434
EMBEDDING_MODEL=ollama/nomic-embed-text

# --- Base de datos ---
DATABASE_URL=sqlite+aiosqlite:///./agrisearch.db

# --- Qdrant (vectorial) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ══════════════════════════════════════════════════════════════════
# APIs de Bases de Datos Científicas
# ══════════════════════════════════════════════════════════════════

# --- Crossref (GRATIS — no requiere key) ---
# Solo un email para el "polite pool" (trato preferencial en rate limits).
# No necesitas registrarte, solo pon tu email.
CROSSREF_MAILTO=tu_email@ejemplo.com

# --- CORE (GRATIS — requiere API key) ---
# Regístrate gratis en: https://core.ac.uk/services/api#form
# Recibirás el API key por email. Cobertura: +280M artículos open access.
CORE_API_KEY=

# --- Redalyc (GRATIS — requiere token) ---
# Regístrate gratis en: http://api.redalyc.org/docs/#/
# Ve a "Generador de consultas API" para obtener tu token.
# Cobertura: revistas científicas de Iberoamérica (ideal para agro en español).
REDALYC_TOKEN=

# --- OpenAlex (GRATIS — key opcional pero recomendada) ---
# Regístrate gratis en: https://openalex.org/settings/api
# Sin key funciona pero con rate limits más restrictivos.
OPENALEX_KEY=

# --- Semantic Scholar (GRATIS — key opcional) ---
# Solicita API key en: https://www.semanticscholar.org/product/api
# Sin key: 100 req/5min. Con key: 1 req/seg.
SEMANTIC_SCHOLAR_KEY=

# ══════════════════════════════════════════════════════════════════
# Las siguientes bases NO requieren key:
# - ArXiv (libre)
# - SciELO (libre — ArticleMeta REST API)
# - AgEcon Search (OAI-PMH libre — ageconsearch.umn.edu)
# - Organic Eprints (OAI-PMH libre — orgprints.org)
# ══════════════════════════════════════════════════════════════════
