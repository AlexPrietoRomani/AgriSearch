# Python Globals
__pycache__/
*.py[cod]
*$py.class
*.so

# OS Globals
.DS_Store
Thumbs.db
desktop.ini

# Environment Variables
.env


# Local data and DBs
/data/
!/data/.gitkeep
/vector_db/
!/vector_db/.gitkeep
*.sqlite3
*.db
.pytest_cache/

# Backend Specific
backend/venv/
backend/env/
backend/.venv/
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/.tox/
backend/.mypy_cache/
backend/build/
backend/dist/
backend/*.egg-info/
backend/.eggs/
backend/lib/
backend/lib64/
backend/var/
backend/parts/

# Frontend (additional protection, rely on frontend/.gitignore primarily)
frontend/node_modules/
frontend/dist/
frontend/.astro/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# IDE and Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Documentos
*.pdf
*.docx

# Agent and Planning
.agents/

# Logs
*.log