*.py[cod]
*$py.class
*.so
.pytest_cache/
pytest.ini
.tox/
.coverage
.mypy_cache/
htmlcov/
build/
dist/
*.egg-info/
.eggs/
nosetests.xml
coverage.xml
*.cover
pip-log.txt
pip-delete-this-directory.txt

# Backend specific paths
backend/venv/
backend/env/
backend/.venv/
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/.tox/
backend/.mypy_cache/
backend/build/
backend/dist/
backend/*.egg-info/
backend/.eggs/
backend/lib/
backend/lib64/
backend/var/
backend/parts/

# --- Frontend (Node / Astro) ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.astro/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
.npm
.eslintcache

